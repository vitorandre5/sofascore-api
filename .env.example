PORT=8080
NODE_ENV=production
CORS_ORIGIN=*
API_PREFIX=/api
REQUEST_TIMEOUT=10000
SOFASCORE_FALLBACK_BASE_URLS=
UPSTREAM_RETRIES=3
UPSTREAM_RETRY_BACKOFF_MS=300
TOP_MATCHES_LIMIT=50
PRELOAD_INTERVAL_MS=30000

# Optional variables already available in your Coolify server.
# Keep them if you later add cache, logs or persistence.
USER_SUPABASE=
PASSWD_SUPABASE=
